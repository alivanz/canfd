	sdc_dio_get_info

		# Syntax:
			int sdc_dio_get_info(
				_IN_ int line,
				_OUT_ struct sdc_dio_info *info
				);

		# Parameter:
			line: Line number.
			info: Information.

		# Description:
			Get controller information.

			In struct sdc_dio_bank_info {...}
				nr_port: Number of I/O port in this bank.
				cap_input: Bank input capability (0->NO, 1->YES).
				cap_output: Bank output capability (0->NO, 1->YES).
				cap_rising_trigger: Bank input event rising trigger
					capability (0->NO, 1->YES).
				cap_falling_trigger: Bank input event falling trigger
					capability (0->NO, 1->YES).

			In struct sdc_dio_info {...}
				pci_bus: PCI bus number.
				irq: IRQ number.
				line: Controller line number (/dev/sdc_dio#).
				index: SDC controller index number.
				version: Controller version.
				cap_samedirection: Bank share same direction capability
					(0->NO, 1->YES).
				cap_storeflash: Store output initial value into FLASH
					capability (0->NO, 1->YES).
				nr_bank: Number of bank in this controller.
				di_sampling_freq: DI sampling frequency (HZ).
				di_filter_lower_bound_ms: DI sampling lower bound value
					(milliseconds).
				di_filter_min_ms: DI sampling min value (milliseconds).
				di_filter_max_ms: DI sampling max value (milliseconds).
				banks: struct sdc_dio_bank_info

		# Return Value:
			On success, return 0.
			On error, refer to return code define.

