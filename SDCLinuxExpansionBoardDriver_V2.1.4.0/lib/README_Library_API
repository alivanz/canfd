	sdc_dio_set_bank_direction

		# Syntax:
			int sdc_dio_set_bank_direction(
				_IN_ int line,
				_IN_ int bank_idx,
				_IN_ int value
				);

		# Parameter:
			line: Line number.
			bank_idx: BANK index.
			value: Direction.

		# Description:
			Set direction.

			Each bit of value present each BANK I/O port, 0 is input,
			1 is output.

